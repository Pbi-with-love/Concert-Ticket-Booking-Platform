datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Concert {
  id          String   @id @default(uuid())
  name        String
  venue       String
  startTime   DateTime
  status      String

  ticketCategories TicketCategory[]
  bookings         Booking[]

  @@index([startTime, id])
  @@index([status, startTime])
}

model TicketCategory {
  id                  String   @id @default(uuid())
  concertId           String
  name                String
  price               Decimal
  totalQuantity       Int
  availableQuantity   Int

  concert        Concert       @relation(fields: [concertId], references: [id])
  bookingItems   BookingItem[]
  attendees      Attendee[]

  @@index([concertId, name])
}

model Voucher {
  id             String   @id @default(uuid())
  code           String   @unique
  
  // PERCENTAGE | FIXED
  discountType   String
  discountValue  Decimal
  maxUsage       Int
  usedCount      Int      @default(0)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean  @default(true)

  bookings       Booking[]
}

model Booking {
  id                String   @id @default(uuid())
  bookingCode       String   @unique
  customerEmail     String
  customerName      String
  customerPhone     String

  concertId         String
  voucherId         String?

  // PENDING | CONFIRMED | CANCELLED | EXPIRED
  status            String
  subtotal          Decimal  @default(0)
  discountAmount    Decimal  @default(0)
  finalAmount       Decimal  @default(0)

  idempotencyKey    String   @unique
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  concert           Concert   @relation(fields: [concertId], references: [id])
  voucher           Voucher?  @relation(fields: [voucherId], references: [id])

  bookingItems      BookingItem[]
  payments          Payment[]

  @@index([customerEmail])
  @@index([concertId])
}

model BookingItem {
  id                String   @id @default(uuid())
  bookingId         String
  ticketCategoryId  String

  quantity          Int
  unitPrice         Decimal
  lineTotal         Decimal

  booking           Booking         @relation(fields: [bookingId], references: [id])
  ticketCategory    TicketCategory  @relation(fields: [ticketCategoryId], references: [id])

  attendees         Attendee[]

  @@index([bookingId])
  @@index([ticketCategoryId])
}

model Payment {
  id              String   @id @default(uuid())
  bookingId       String

  provider        String
  transactionId   String   @unique
  amount          Decimal
  // PENDING | SUCCESS | FAILED
  status          String

  createdAt       DateTime @default(now())
  paidAt          DateTime?

  booking         Booking  @relation(fields: [bookingId], references: [id])
}

model Attendee {
  id              String   @id @default(uuid())

  bookingItemId   String
  ticketCategoryId String

  ticketCode      String   @unique
  fullName        String
  email           String
  phone           String

  /*
    Booking status:
    - PENDING
    - CHECKED_IN
  */
  checkInStatus   String   @default("PENDING")
  checkInAt       DateTime?

  bookingItem     BookingItem   @relation(fields: [bookingItemId], references: [id])
  ticketCategory  TicketCategory @relation(fields: [ticketCategoryId], references: [id])
}
