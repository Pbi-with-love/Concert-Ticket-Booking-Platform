                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Taylor Live in HCMC\",\n  \"venue\": \"SECC\",\n  \"startTime\": \"2026-06-01T19:30:00.000Z\",\n  \"status\": \"PUBLISHED\",\n  \"ticketCategories\": [\n    {\n      \"name\": \"VIP\",\n      \"price\": 1500000,\n      \"totalQuantity\": 100,\n      \"availableQuantity\": 100\n    },\n    {\n      \"name\": \"Standard\",\n      \"price\": 800000,\n      \"totalQuantity\": 300,\n      \"availableQuantity\": 300\n    }\n  ]\n}"
            },
